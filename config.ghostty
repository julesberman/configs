# ~/.config/ghostty/config
# Reload with cmd+shift+, on macOS

# ─── Theme & appearance ─────────────────────────────────
# Run `ghostty +list-themes` to browse.
theme = Ayu

# ─── Fonts ──────────────────────────────────────────────
# Monaspace Argon as primary, with other Monaspace variants
# for italic/bold so text gets subtle texture variation.
font-family       = "Monaspace Argon"
font-style        = "Regular"
font-family-bold  = "Monaspace Argon"
font-style-bold   = "Bold"
font-family-italic = "Monaspace Radon"
font-style-italic  = "Italic"
font-family-bold-italic = "Monaspace Krypton"
font-style-bold-italic  = "Bold Italic"
font-size         = 14

# Monaspace ships with ligatures + "texture healing" stylistic sets.
# calt = contextual alternates (texture healing), liga = ligatures,
# ss01-ss09 = stylistic sets. ss01 enables texture healing.
font-feature = +calt
font-feature = +liga
font-feature = +ss01
font-feature = +ss02
font-feature = +ss03

# Slightly tighter line height feels better with Argon
adjust-cell-height = -5%

# Padding so text doesn't hug the edges
window-padding-x = 14
window-padding-y = 12
window-padding-balance = true

# Cursor
cursor-style = bar
cursor-style-blink = true
shell-integration-features = cursor,sudo,title

# Hide the mouse cursor while typing
mouse-hide-while-typing = true

# ─── Scrollback & behavior ──────────────────────────────
copy-on-select   = clipboard

# ─── Quick terminal (drop-down, Warp-style) ─────────────
quick-terminal-position = top
quick-terminal-animation-duration = 0.15
keybind = global:cmd+grave_accent=toggle_quick_terminal

# ─── Claude Code / power-user keybinds ──────────────────
# Splits — handy for running Claude Code in one pane,
# tests/logs/git in another.
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface
keybind = cmd+[=goto_split:previous
keybind = cmd+]=goto_split:next
keybind = cmd+shift+enter=toggle_split_zoom

# Jump between shell prompts (needs shell integration, which
# Ghostty auto-injects for zsh/bash/fish). Great for scrubbing
# through a long Claude Code session.
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

# Dump the scrollback to $EDITOR — lifesaver when Claude Code
# produces a wall of output you want to search/save.
keybind = cmd+shift+o=write_scrollback_file:open
